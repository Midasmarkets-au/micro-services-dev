{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["build.client", "build.tenant", "build.backend"]
    },
    "build.client": {
      "outputs": ["dist/client/**"],
      "env": [
        "VUE_APP_NAME",
        "VUE_APP_VERSION",
        "VUE_APP_CLIENT_ID",
        "VUE_APP_GRANT_TYPE",
        "VUE_APP_SCOPE",
        "VUE_APP_URL",
        "VUE_APP_PAGE_TITLE",
        "VUE_APP_TOKEN_VALIDITY_PERIOD",
        "VUE_APP_SERVICE_STATUS",
        "VUE_APP_ENV",
        "VUE_APP_GA_ID",
        "VUE_APP_SITE",
        "VUE_APP_PATH",
        "VUE_APP_API_URL",
        "VUE_APP_BASE_URL",
        "VUE_APP_API_V2_URL",
        "VUE_APP_API_V3_URL",
        "VUE_APP_API_WS_URL",
        "VUE_APP_BASE_CDN_URL"
      ]
    },
    "build.tenant": {
      "outputs": ["dist/tenant/**"],
      "env": [
        "VUE_APP_NAME",
        "VUE_APP_VERSION",
        "VUE_APP_CLIENT_ID",
        "VUE_APP_GRANT_TYPE",
        "VUE_APP_SCOPE",
        "VUE_APP_URL",
        "VUE_APP_PAGE_TITLE",
        "VUE_APP_TOKEN_VALIDITY_PERIOD",
        "VUE_APP_SERVICE_STATUS",
        "VUE_APP_ENV",
        "VUE_APP_GA_ID",
        "VUE_APP_SITE",
        "VUE_APP_PATH",
        "VUE_APP_API_URL",
        "VUE_APP_BASE_URL",
        "VUE_APP_API_V2_URL",
        "VUE_APP_API_V3_URL",
        "VUE_APP_API_WS_URL",
        "VUE_APP_BASE_CDN_URL"
      ]
    },
    "build.backend": {
      "outputs": ["dist/backend/**"]
    },
    "dev.client": {
      "cache": false
    },
    "dev.backend": {
      "cache": false
    },
    "dev.tenant": {
      "cache": false
    }
  }
}
