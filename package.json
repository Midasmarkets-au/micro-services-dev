    "test": "echo \"Error: no test specified\" && exit 1",
    "gen:openapi": "node scripts/generate_openapi.js",
    "docs": "node scripts/generate_openapi.js && npx serve docs/openapi -p 8080"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
